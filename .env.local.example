# Copy this file to .env.local and fill in your own Supabase project values.
# Find these in Supabase: Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used only server-side for admin operations (creating team member
# accounts). Find under Project Settings > API Keys ("secret key" or
# "service_role" key). NEVER prefix this with NEXT_PUBLIC_ — it must
# never reach the browser.
SUPABASE_SECRET_KEY=
